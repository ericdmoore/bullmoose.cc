{
  "name": "bullmoose-mail",
  "private": true,
  "description": "Serverless JMAP mail platform — Cloudflare Workers + Durable Objects + D1 + R2, SES outbound",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:jmap": "npm run dev -w services/jmap",
    "dev:ingest": "npm run dev -w services/ingest",
    "dev:submit": "npm run dev -w services/submit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.20.0"
  }
}
