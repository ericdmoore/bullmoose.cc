{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bullmoose-ingest",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",

  // This worker is the Email Routing target ("catch-all → worker") for
  // every hosted zone; the Provisioning worker wires that per domain.

  // AccountDO is declared by bullmoose-jmap; bind it cross-script.
  "durable_objects": {
    "bindings": [
      { "name": "ACCOUNT_DO", "class_name": "AccountDO", "script_name": "bullmoose-jmap" }
    ]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bullmoose-mail-shard0",
      "database_id": "REPLACE_AFTER_wrangler_d1_create"
    }
  ],
  "r2_buckets": [{ "binding": "BLOBS", "bucket_name": "bullmoose-mail-blobs" }],
  "kv_namespaces": [{ "binding": "ROUTES", "id": "REPLACE_AFTER_wrangler_kv_create" }]
}
