---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
const repo = "https://github.com/ericdmoore/bullmoose.cc";
const guides = [
  { label: "Apple Mail + Apple Calendar", href: `${repo}/blob/main/docs/playbooks/apple-mail-and-calendar.md` },
  { label: "A JMAP client (Mailtemi)", href: `${repo}/blob/main/docs/playbooks/jmap-client.md` },
  { label: "Family — shared contacts/calendar", href: `${repo}/blob/main/docs/playbooks/family-sharing.md` },
];
---

<Base title="Connection guides — bullmoose">
  <Nav />
  <main class="wrap page">
    <p class="eyebrow">Connect your clients</p>
    <h1>Guides</h1>
    <p class="lede">
      Step-by-step setups for each client. These will render here as pages soon;
      today they live as playbooks in the repo — same content, one source.
    </p>
    <ul>
      {guides.map((g) => <li><a href={g.href} style="border-bottom:2px solid var(--brass)">{g.label} &rarr;</a></li>)}
    </ul>
    <p style="margin-top:1.8rem">
      <a class="btn btn-ink" href={`${repo}/tree/main/docs/playbooks`}>All playbooks on GitHub &rarr;</a>
    </p>
  </main>
  <Footer />
</Base>
