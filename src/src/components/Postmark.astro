---
// The signature: a mail-cancellation postmark that doubles as a civic seal
// and states the price. Mail motif + campaign badge + "$0" in one mark.
---

<svg class="postmark" viewBox="0 0 200 200" role="img" aria-label="Runs for zero dollars per month">
  <defs>
    <path id="pm-arc" d="M18,100 A82,82 0 0 1 182,100" />
  </defs>

  <!-- outer rings -->
  <circle class="pm-ring" cx="100" cy="100" r="94" stroke-width="2"></circle>
  <circle class="pm-ring" cx="100" cy="100" r="78" stroke-width="3.5"></circle>

  <!-- cancellation lines -->
  <g class="pm-cancel" fill="none" stroke-width="2" stroke-linecap="round">
    <line x1="28" y1="98" x2="172" y2="102" opacity="0.55" />
    <line x1="34" y1="118" x2="166" y2="82" opacity="0.4" stroke-width="1.5" />
  </g>

  <!-- top arc text -->
  <text font-size="16" letter-spacing="5">
    <textPath href="#pm-arc" startOffset="50%" text-anchor="middle">BULLMOOSE.CC</textPath>
  </text>

  <!-- star + establishment -->
  <text x="100" y="66" text-anchor="middle" font-size="15">&#9733;</text>
  <text x="100" y="86" text-anchor="middle" font-size="10.5" letter-spacing="3">EST. YOUR DOMAIN</text>

  <!-- price -->
  <text class="pm-amt" x="100" y="132" text-anchor="middle" font-size="54">$0</text>
  <text x="100" y="152" text-anchor="middle" font-size="11.5" letter-spacing="4">PER MONTH</text>
</svg>
